sadan-demo.duckdns.org {
	# /gemini-voice exempt too: mobile browsers don't attach cached basic-auth
	# credentials to WebSocket upgrades, so voice would never connect on phones.
	@protected not path /api/voice/* /health /gemini-voice*

	basicauth @protected {
		mor $2b$14$yk5vt8LWsGhpXZCJPlGZrO3Lgr/QztPe9jg2DJaqI6W3eDKoNK8GK
		brumer $2b$14$ga43n3jHJW5dEAlUhCsqluDBUYj..IkFo1p1WoWcicuRzVslKytDS
		raz $2b$14$eWbOP6lAt7KSI2qXQQBMKOI.tU7DTTBXKoJYs5YruRgm1jIkiwwlS
	}

	# WhatsApp server — strip /wa prefix
	handle_path /wa/* {
		reverse_proxy whatsapp:3001
	}

	# Backend API + Vonage webhooks + health
	handle /api/* {
		reverse_proxy backend:8000
	}

	handle /health {
		reverse_proxy backend:8000
	}

	# Gemini Live WebSocket
	handle /gemini-voice* {
		reverse_proxy backend:8000
	}

	# Frontend SPA
	handle {
		root * /srv/dist
		try_files {path} /index.html
		file_server
	}
}
